{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd devscroll-backend && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "cd devscroll-backend && uvicorn main:app --host 0.0.0.0 --port $PORT",
    "restartPolicyType": "on_failure"
  }
}
